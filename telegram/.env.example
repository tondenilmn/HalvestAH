# Copy this file to .env for local overrides (optional — you can also edit config.js directly).
# On Railway: set these as environment variables in the Railway dashboard.

# Required
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Required on Railway — base URL of your deployed Cloudflare Pages site.
# The notifier will fetch /data/manifest.json then each CSV from this URL.
# Example: https://halvest-ah.pages.dev
DATA_URL=https://your-project.pages.dev

# Optional overrides
# LEAGUE_TIER=ALL           # ALL | TOP | MAJOR | TOP+MAJOR
# SCAN_INTERVAL_MINUTES=5
